<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TgNotifier" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/accent_blue_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlHighlight">#1A2AABEE</item>
        <item name="tabStyle">@style/Widget.TgNotifier.TabLayout</item>
    </style>

    <style name="Widget.TgNotifier.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/accent_blue</item>
        <item name="tabSelectedTextColor">@color/accent_blue</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorFullWidth">false</item>
    </style>
</resources>
